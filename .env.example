# ICON Interface Configuration
# Copy this file to .env and fill in your values

# ICON Interface host (default: localhost)
ICON_LASER_HOST=localhost

# ICON Interface port (default: 5287)
ICON_LASER_PORT=5287

# Request timeout in seconds (default: 5)
ICON_LASER_TIMEOUT=5

# Marking job to run (required for integration tests)
ICON_LASER_JOB=test_job

# ID field name to set (default: SN)
ICON_LASER_ID_NAME=SN

# ID value to set (default: TEST123)
ICON_LASER_ID_VALUE=TEST123
